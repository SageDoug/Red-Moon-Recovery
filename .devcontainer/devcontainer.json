{
  "name": "Red Moon Recovery",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Red Moon Recovery App",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "chmod +x startup.sh && pip install -r requirements.txt",
  "postStartCommand": "python app.py"
}
